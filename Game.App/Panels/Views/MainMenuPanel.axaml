<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="using:Game.App.Panels"
             x:Class="Game.App.Panels.Views.MainMenuPanel"
             x:DataType="panels:MainMenuPanelViewModel">

    <StackPanel Spacing="10" IsVisible="{Binding IsVisible}">
        <TextBlock Text="新しい冒険を始める" FontSize="18" FontWeight="Bold"/>
        <Button Content="新規ゲーム開始" Command="{Binding StartGameCommand}" 
                Width="200" HorizontalAlignment="Left"/>
    </StackPanel>

</UserControl>
